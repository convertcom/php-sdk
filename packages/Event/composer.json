{
    "name": "convertcom/php-sdk-event",
    "description": "Convert PHP SDK Event Manager",
    "type": "library",
    "license": "Apache-2.0",
    "version": "1.0.0",
    "authors": [
      {
        "name": "Convert Insights, Inc"
      }
    ],
    "autoload": {
      "psr-4": {
        "ConvertSdk\\": "src/"
      }
    },
    "repositories": {
        "Enums": {
            "type": "path",
            "url": "../Enums"
        },
        "Logger": {
            "type": "path",
            "url": "../Logger"
        },
        "Types": {
            "type": "path",
            "url": "../Types"
        }
    },
    "require": {
      "php": "^8.2",
      "convertcom/php-sdk-enums": ">=1.0.0",
      "convertcom/php-sdk-logger": ">=1.0.0",
      "convertcom/php-sdk-types": ">=1.0.0"
    },
    "require-dev": {
      "phpunit/phpunit": "^11.0",
      "vlucas/phpdotenv": "^5.5"
    },
    "scripts": {
      "test": "phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
  }
  