{
    "name": "convertcom/php-sdk-event",
    "description": "Convert PHP SDK Event Manager",
    "type": "library",
    "license": "Apache-2.0",
    "version": "1.0.0",
    "authors": [
      {
        "name": "Convert Insights, Inc"
      }
    ],
    "autoload": {
      "psr-4": {
        "ConvertSdk\\": "src/"
      }
    },
    "repositories": {
        "Enums": {
            "type": "path",
            "url": "../Enums"
        },
        "Logger": {
            "type": "path",
            "url": "../Logger"
        }
    },
    "require": {
      "php": ">=7.4",
      "convertcom/php-sdk-enums": ">=1.0.0",
      "convertcom/php-sdk-logger": ">=1.0.0"
    },
    "require-dev": {
      "phpunit/phpunit": "^10.0",
      "vlucas/phpdotenv": "^5.5",
      "squizlabs/php_codesniffer": "^3.8",
      "phpstan/phpstan": "^1.11",
      "friendsofphp/php-cs-fixer": "^3.30"
    },
    "scripts": {
      "test": "phpunit",
      "lint": "phpcs",
      "lint:fix": "phpcbf",
      "phpstan": "phpstan analyse src --level=max"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
  }
  