{
    "name": "convertcom/php-sdk-utils",
    "description": "Convert Insights PHP SDK Utils",
    "type": "library",
    "license": "Apache-2.0",
    "authors": [
        {
        "name": "Convert Insights, Inc",
        "homepage": "https://www.convert.com"
        }
    ],
    "autoload": {
        "psr-4": {
        "ConvertSdk\\Utils\\": "src/"
        }
    },
    "repositories": {
        "Enums": {
        "type": "path",
        "url": "../Enums"
      }
    },
    "require": {
        "php": ">=7.4",
        "convertcom/php-sdk-enums": "^1.0.0",
        "guzzlehttp/guzzle": "^7.9",
        "lastguest/murmurhash": "^2.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5 || ^10.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "lint:fix": "vendor/bin/php-cs-fixer fix"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "version": "1.0.0"

}
