<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/10.5/phpunit.xsd"
    bootstrap="vendor/autoload.php"
    colors="true"
>
    <!-- Define the test suites -->
    <testsuites>
        <testsuite name="ConvertSdk Tests">
            <directory suffix="Test.php">tests</directory>
        </testsuite>
    </testsuites>

    <!-- PHP settings and environment variables -->
    <php>
        <env name="CONFIG_ENDPOINT" value="http://127.0.0.1:9501"/>
        <env name="TRACK_ENDPOINT" value="http://127.0.0.1:9501"/>
        <env name="PHPUNIT_DB_HOST" value="localhost"/>
    </php>

</phpunit>