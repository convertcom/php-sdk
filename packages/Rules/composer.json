{
    "name": "convertcom/php-sdk-rules",
    "description": "PHP SDK for Convert Rules",
    "type": "library",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Convert Insights, Inc"
        }
    ],
    "autoload": {
        "psr-4": {
            "ConvertSdk\\": "src/",
            "ConvertSdk\\Config\\": "../Php-sdk/src/Config/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../Enums"
        },
        {
            "type": "path",
            "url": "../Logger"
        },
        {
            "type": "path",
            "url": "../Utils"
        },
        {
            "type": "path",
            "url": "../Types"
        }
    ],
    "require": {
        "php": "^8.2",
        "convertcom/php-sdk-enums": "^1.0.0",
        "convertcom/php-sdk-logger": "^1.0.0",
        "convertcom/php-sdk-utils": "^1.0.0",
        "convertcom/php-sdk-types": "^1.0.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "test": "phpunit",
        "build": "php build.php"
    },
    "version": "1.0.0"
}
