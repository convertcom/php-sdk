{
    "name": "convertcom/php-sdk-rules",
    "description": "PHP SDK for Convert Rules",
    "type": "library",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Convert Insights, Inc"
        }
    ],
    "autoload": {
        "psr-4": {
            "ConvertSdk\\": "src/",
            "ConvertSdk\\Config\\": "../Php-sdk/src/Config/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../Enums"
        },
        {
            "type": "path",
            "url": "../Logger"
        },
        {
            "type": "path",
            "url": "../Utils"
        }
    ],
    "require": {
        "php": ">=7.4",
        "convertcom/php-sdk-enums": ">=1.0.0",
        "convertcom/php-sdk-logger": ">=1.0.0",
        "convertcom/php-sdk-utils": ">=1.0.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "squizlabs/php_codesniffer": "^3.6"
    },
    "scripts": {
        "lint": "phpcs --standard=PSR12 src",
        "test": "phpunit",
        "build": "php build.php"
    },
    "version": "1.0.0"
}
