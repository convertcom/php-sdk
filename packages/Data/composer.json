{
    "name": "convertcom/php-sdk-data",
    "description": "PHP SDK Data package for Convert Insights, Inc.",
    "type": "library",
    "license": "Apache-2.0",
    "version": "1.0.0",
    "authors": [
      {
        "name": "Convert Insights, Inc"
      }
    ],
    "autoload": {
      "psr-4": {
        "ConvertSdk\\Data\\": "src/"
      }
    },
    "repositories": {
      "Enums": {
        "type": "path",
        "url": "../Enums"
      },
      "Api": {
        "type": "path",
        "url": "../Api"
      },
      "Logger": {
        "type": "path",
        "url": "../Logger"
      },
      "Utils": {
        "type": "path",
        "url": "../Utils"
      },
      "Event": {
        "type": "path",
        "url": "../Event"
      }
    },
    "require": {
      "php": ">=7.4",
      "convertcom/php-sdk-api": ">=1.0.0",
      "convertcom/php-sdk-enums": ">=1.0.0",
      "convertcom/php-sdk-event": ">=1.0.0",
      "convertcom/php-sdk-logger": ">=1.0.0",
      "convertcom/php-sdk-utils": ">=1.0.0"
    },
    "require-dev": {
      "phpunit/phpunit": "^9.0",
      "phpstan/phpstan": "^1.0",
      "squizlabs/php_codesniffer": "^3.0",
      "friendsofphp/php-cs-fixer": "^3.0"
    },
    "scripts": {
      "test": "vendor/bin/phpunit",
      "lint": "vendor/bin/phpcs",
      "lint:fix": "vendor/bin/php-cs-fixer fix",
      "coverage": "vendor/bin/phpunit --coverage-text"
    },
    "config": {
      "optimize-autoloader": true,
      "sort-packages": true
    }
  }
