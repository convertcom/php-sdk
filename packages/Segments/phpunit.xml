<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
    bootstrap="vendor/autoload.php"
    colors="true"
    stopOnFailure="false"
>
    <testsuites>
        <testsuite name="ConvertSdk Tests">
            <directory>./tests</directory>
        </testsuite>
    </testsuites>
    <php>
        <env name="CONFIG_ENDPOINT" value="http://your-api-endpoint"/>
        <env name="TRACK_ENDPOINT" value="http://your-track-endpoint"/>
        <env name="PHPUNIT_DB_HOST" value="localhost"/>
    </php>
    <source>
        <include>
            <directory>src</directory>
        </include>
    </source>
</phpunit>
