{
    "name": "convertcom/php-sdk-experience",
    "description": "PHP SDK for Convert Experience Management",
    "type": "library",
    "license": "Apache-2.0",
    "authors": [
      {
        "name": "Convert Insights, Inc",
        "email": "support@convert.com"
      }
    ],
    "autoload": {
      "psr-4": {
        "ConvertSdk\\Experience\\": "src/"
      }
    },
    "repositories": [
      {
        "type": "path",
        "url": "../Api"
      },
      {
        "type": "path",
        "url": "../Enums"
      },
      {
        "type": "path",
        "url": "../Logger"
      },
      {
        "type": "path",
        "url": "../Event"
      },
      {
        "type": "path",
        "url": "../Utils"
      },
      {
        "type": "path",
        "url": "../Data"
      }
    ],
    "require": {
      "php": ">=7.4",
      "guzzlehttp/guzzle": "^7.0",
      "convertcom/php-sdk-api": ">=1.0.0",
      "convertcom/php-sdk-enums": ">=1.0.0",
      "convertcom/php-sdk-logger": ">=1.0.0",
      "convertcom/php-sdk-data": ">=1.0.0"
    },
    "require-dev": {
      "phpunit/phpunit": "^9.6",
      "phpstan/phpstan": "^1.0",
      "squizlabs/php_codesniffer": "^3.6",
      "mockery/mockery": "^1.4"
    },
    "scripts": {
      "test": "phpunit --config phpunit.xml",
      "lint": "phpcs --standard=PSR12 src/ tests/",
      "lint:fix": "phpcbf --standard=PSR12 src/ tests/",
      "clean": "rm -rf vendor/ composer.lock",
      "post-install-cmd": [
        "php -r \"copy('https://getcomposer.org/installer', 'composer-setup.php');\"",
        "php composer-setup.php --install-dir=/usr/local/bin --filename=composer"
      ]
    },
    "config": {
      "preferred-install": "dist",
      "optimize-autoloader": true,
      "platform": {
        "php": "7.4.3"
      }
    },
    "version": "1.0.0",
    "minimum-stability": "stable",
    "prefer-stable": true
  }
  