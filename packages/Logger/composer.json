{
  "name": "convertcom/php-sdk-logger",
  "description": "PHP implementation of Convert SDK Logger package",
  "type": "library",
  "license": "Apache-2.0",
  "version": "1.0.0",
  "authors": [
    {
      "name": "Convert Insights, Inc"
    }
  ],
  "autoload": {
    "psr-4": {
      "ConvertSdk\\": "src/"
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../Enums"
    }
  ],
  "require": {
    "php": "^8.2",
    "convertcom/php-sdk-enums": ">=1.0.0",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "monolog/monolog": "^3.8"
  },
  "scripts": {
    "test": "phpunit"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
