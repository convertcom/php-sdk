{
    "name": "convertcom/php-sdk-monorepo",
    "description": "PHP SDK Monorepo for Convert Insights",
    "type": "project",
    "license": "Apache-2.0",
    "private": true,
    "repositories": [
        { "type": "path", "url": "packages/Api" },
        { "type": "path", "url": "packages/Bucketing" },
        { "type": "path", "url": "packages/Data" },
        { "type": "path", "url": "packages/Enums" },
        { "type": "path", "url": "packages/Event" },
        { "type": "path", "url": "packages/Experience" },
        { "type": "path", "url": "packages/Logger" },
        { "type": "path", "url": "packages/Rules" },
        { "type": "path", "url": "packages/Segments" },
        { "type": "path", "url": "packages/Types" },
        { "type": "path", "url": "packages/Utils" },
        { "type": "path", "url": "packages/Php-sdk" }
    ],
    "require": {
        "php": "^8.2",
        "convertcom/php-sdk-api": ">=1.0.0",
        "convertcom/php-sdk-data": ">=1.0.0",
        "convertcom/php-sdk-enums": ">=1.0.0",
        "convertcom/php-sdk-event": ">=1.0.0",
        "convertcom/php-sdk-logger": ">=1.0.0",
        "convertcom/php-sdk-utils": ">=1.0.0",
        "convertcom/php-sdk": ">=1.0.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "symplify/monorepo-builder": "^12.0",
        "php-http/mock-client": "^1.6",
        "nyholm/psr7": "^1.8"
    },
    "autoload-dev": {
        "psr-4": {
            "ConvertSdk\\Tests\\CrossSdk\\": "tests/CrossSdk/",
            "ConvertSdk\\Tests\\Integration\\": "tests/Integration/"
        }
    },
    "scripts": {
        "analyze": "phpstan analyse",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:cross-sdk": "phpunit --testsuite cross-sdk",
        "test:integration": "phpunit --testsuite integration",
        "test:coverage": "phpunit --coverage-html coverage-report",
        "api:build": "cd packages/Api && composer run-script build",
        "data:build": "cd packages/Data && composer run-script build",
        "enums:build": "cd packages/Enums && composer run-script build",
        "event:build": "cd packages/Event && composer run-script build",
        "logger:build": "cd packages/Logger && composer run-script build",
        "utils:build": "cd packages/Utils && composer run-script build",
        "sdk:build": "cd packages/Php-sdk && composer run-script build",
        "build": [
            "@build:validate",
            "@test",
            "@analyze",
            "@cs-check"
        ],
        "build:validate": "monorepo-builder validate",
        "build:merge": "monorepo-builder merge"
    }
}
